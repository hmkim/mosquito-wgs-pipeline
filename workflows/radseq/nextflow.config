/*
 * NEA/EHI RADseq Pipeline — Nextflow Configuration
 * Platform: AWS HealthOmics
 */

manifest {
    name            = 'nea-ehi-radseq'
    author          = 'NEA/EHI POC Team'
    description     = 'RADseq variant calling pipeline for Aedes aegypti'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '1.0.0'
}

// Default parameters
params {
    reads        = null
    reference    = null
    outdir       = null
    use_denovo   = false
    min_quality  = 20
    min_length   = 50
}

// AWS HealthOmics profile
profiles {
    healthomics {
        process {
            executor = 'awsbatch'

            withLabel: 'low' {
                cpus   = 2
                memory = '4 GB'
            }
            withLabel: 'medium' {
                cpus   = 4
                memory = '8 GB'
            }
            withLabel: 'high' {
                cpus   = 8
                memory = '16 GB'
            }
        }

        aws {
            region = 'ap-southeast-1'
        }

        docker {
            enabled = true
        }
    }

    // Local testing profile
    local {
        process {
            executor = 'local'
            cpus     = 4
            memory   = '8 GB'
        }

        docker {
            enabled = true
        }
    }
}

// Container
process {
    container = 'ECR_ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/nea-ehi-radseq:latest'
}

// Timeline and report
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,%cpu,%mem,rss,peak_rss'
}
